/target/

# Local-only working memos (drafts / notes). Convention: prefix the
# filename with `_` and the file stays off-disk.
_*.md

# Audit receipts written by the code-audit skill (local-only).
.audit/

# Sub-agent isolated worktrees created by the Claude harness.
.claude/worktrees/
**/.claude/settings.local.json

# Local development scaffolding (scratch experiments, ad-hoc
# benchmarks). Release-candidate fixtures go under tests/fixtures/.
.scratch/

# Local SQLite stores used during development. The daemon writes
# real indexes under the OS data dir; devs may keep throwaway DBs
# in the tree for iteration.
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Secrets — never commit. `.env.example` is the documented escape
# hatch for example files.
.env
.env.*
!.env.example
*.pem
*.key
